# Copy to `.env` or export these variables before running docker compose.
#
# This file intentionally keeps model/data paths container-relative. The
# docker-compose volumes mount the host project data into the same locations.

BACKEND_PORT=8190

# CUDA runtime defaults. Use `sdpa` only for CPU/macOS-like environments where
# FlashAttention 2 is unavailable.
QWEN_DEMO_SIMULATION=0
QWEN_DEMO_DEVICE=cuda:0
QWEN_DEMO_ATTN_IMPL=flash_attention_2
QWEN_DEMO_PYTHON=/app/.venv/bin/python
QWEN_EXTENSIONS=/app/qwen_extensions

# Data/model roots.
HF_HOME=/app/data/cache/huggingface
TORCH_HOME=/app/data/cache/torch
XDG_CACHE_HOME=/app/data/cache
MPLCONFIGDIR=/app/data/cache/matplotlib

# Local S2-Pro / Fish Speech. The backend auto-starts the local server.
S2_PRO_RUNTIME=local
S2_PRO_AUTO_START=1
FISH_SPEECH_SERVER_URL=http://127.0.0.1:8080
FISH_SPEECH_MODEL=s2-pro
FISH_SPEECH_VENV=/app/.venv-fish-speech
FISH_SPEECH_PYTHON=/app/.venv-fish-speech/bin/python

# External tool runtimes. These venvs are created by the setup profile:
# docker compose --profile setup run --rm model-setup
ACE_STEP_VENV=/app/.venv-ace-step
ACE_STEP_PYTHON=/app/.venv-ace-step/bin/python
ACE_STEP_CHECKPOINT_PATH=/app/data/models/ace-step
VIBEVOICE_MODEL_DIR=/app/data/models/vibevoice
VIBEVOICE_PYTHON=/app/.venv-vibevoice/bin/python
APPLIO_REPO_ROOT=/app/vendor/Applio
MMAUDIO_REPO_ROOT=/app/vendor/MMAudio
FISH_SPEECH_REPO_ROOT=/app/vendor/fish-speech
ACE_STEP_REPO_ROOT=/app/vendor/ACE-Step
VIBEVOICE_REPO_ROOT=/app/vendor/VibeVoice

# Optional private asset mirror.
PRIVATE_ASSET_REVISION=main
QWEN_USE_PRIVATE_ASSET_REPO=0
HF_HUB_ENABLE_HF_TRANSFER=1
# HF_TOKEN=
# PRIVATE_ASSET_REPO_ID=your-hf-username/qwen3-tts-demo-assets

