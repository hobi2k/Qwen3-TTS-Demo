# Copy this file to `app/backend/.env`.
#
# Keep machine-specific absolute paths in your local `.env` only. The template
# intentionally uses repository-relative defaults so a fresh clone can be moved
# without rewriting configuration.

# ---------------------------------------------------------------------------
# Core Qwen runtime
# ---------------------------------------------------------------------------

# 0 = use real models. 1 = skip heavyweight model calls for UI/API smoke tests.
QWEN_DEMO_SIMULATION=0

# Leave unset for auto detection.
# - Apple Silicon: mps
# - NVIDIA CUDA: cuda:0
# - CPU-only: cpu
# QWEN_DEMO_DEVICE=

# Leave unset for auto attention selection.
# - Linux/Windows + CUDA + flash_attn installed: flash_attention_2
# - macOS / CPU / unsupported CUDA: sdpa
# QWEN_DEMO_ATTN_IMPL=

# Optional model path overrides. If unset, the backend resolves models from
# `data/models/*` after `./scripts/download_models.sh`.
# QWEN_DEMO_CUSTOM_MODEL=
# QWEN_DEMO_DESIGN_MODEL=
# QWEN_DEMO_BASE_MODEL=
# QWEN_DEMO_TOKENIZER_MODEL=
# QWEN_DEMO_ASR_MODEL=Qwen/Qwen3-ASR-1.7B
# QWEN_DEMO_ASR_MAX_NEW_TOKENS=512

# Demo-owned Qwen scripts. Leave unset to use repository-local `qwen_extensions`.
# QWEN_EXTENSIONS=qwen_extensions

# Upload/generated audio sanity checks.
QWEN_DEMO_MIN_AUDIO_DURATION_SEC=0.25
QWEN_DEMO_MIN_AUDIO_RMS=0.003
QWEN_DEMO_MIN_AUDIO_PEAK=0.02

# Training helper defaults.
# Leave QWEN_DEMO_PYTHON unset to use the same Python executable that runs the
# backend. Set it only when you intentionally want a different interpreter.
# QWEN_DEMO_PYTHON=python3.11
# QWEN_DEMO_TRAIN_PRECISION=
# QWEN_DEMO_OPTIMIZER=adafactor
# QWEN_DEMO_GRAD_ACCUM_STEPS=1
# QWEN_DEMO_LOG_EVERY=25

# ---------------------------------------------------------------------------
# Vendored audio tool repositories
# ---------------------------------------------------------------------------

# Third-party source trees are vendored in this repository. Setup/download
# scripts must not clone them again. If a vendor directory is missing, restore
# the repository contents instead of setting a git URL here.
#
# Optional repo root overrides. Leave unset for normal use. Defaults:
# - vendor/MMAudio
# - vendor/Applio
# - vendor/fish-speech
# - vendor/ACE-Step
# - vendor/VibeVoice
# MMAUDIO_REPO_ROOT=
# APPLIO_REPO_ROOT=
# FISH_SPEECH_REPO_ROOT=
# ACE_STEP_REPO_ROOT=
# VIBEVOICE_REPO_ROOT=

# ---------------------------------------------------------------------------
# VibeVoice ASR / TTS
# ---------------------------------------------------------------------------

# VibeVoice is handled as a vendored tool like S2-Pro, MMAudio, Applio, and
# ACE-Step. The code vendor is the community-maintained fork because it keeps
# long-form TTS/7B inference and community fine-tuning available. The ASR and
# realtime model weights still come from the official Microsoft HF repos.
# `./scripts/download_models.sh vibevoice` expects vendor/VibeVoice to already
# exist in this repository, creates `.venv-vibevoice`, and downloads all
# required model families:
# - microsoft/VibeVoice-ASR
# - microsoft/VibeVoice-Realtime-0.5B
# - vibevoice/VibeVoice-1.5B
# Optional community large model:
# - vibevoice/VibeVoice-7B (`./scripts/download_models.sh vibevoice-7b`)
#
# Current official VibeVoice releases keep ASR/realtime inference runnable and
# may omit the old long-form 1.5B TTS entrypoint. This app includes
# `scripts/run_vibevoice_tts_15b.py` plus a local compatibility patch so the
# 1.5B weights have a default executable path.
# VIBEVOICE_MODEL_DIR=data/models/vibevoice
# VIBEVOICE_PYTHON=.venv-vibevoice/bin/python
# VIBEVOICE_ASR_MODEL_PATH=data/models/vibevoice/VibeVoice-ASR
# VIBEVOICE_REALTIME_MODEL_PATH=data/models/vibevoice/VibeVoice-Realtime-0.5B
# VIBEVOICE_TTS_15B_MODEL_PATH=data/models/vibevoice/VibeVoice-1.5B
# VIBEVOICE_TTS_7B_MODEL_PATH=data/models/vibevoice/VibeVoice-7B
# VIBEVOICE_TTS_15B_INFERENCE_STEPS=10
# VIBEVOICE_TTS_7B_INFERENCE_STEPS=12
#
# Official Microsoft VibeVoice currently exposes ASR LoRA fine-tuning. TTS
# LoRA/full fine-tuning is not shipped as an official trainer in the vendor
# repo, so this app only runs it when you explicitly provide a command template.
# VIBEVOICE_TTS_FINETUNE_COMMAND_TEMPLATE=

# Optional command templates. Placeholders include:
# {python}, {repo}, {model}, {model_profile}, {audio}, {text}, {text_file},
# {output}, {output_dir}, {language}, {speaker}, {speaker_audio},
# {speaker_prompt_text}, {cfg_scale}, {temperature}, {top_p}, {seed},
# {device}, {precision}, {max_new_tokens}, {num_beams}, {task},
# {speaker_names}, {speaker_audio_paths}, {attn_implementation},
# {inference_steps}, {max_length_times}, {disable_prefill}, {show_progress}
# VIBEVOICE_ASR_COMMAND_TEMPLATE=
# VIBEVOICE_TTS_COMMAND_TEMPLATE=
# VIBEVOICE_TTS_15B_COMMAND_TEMPLATE=
# VIBEVOICE_TTS_7B_COMMAND_TEMPLATE=

# ---------------------------------------------------------------------------
# S2-Pro provider
# ---------------------------------------------------------------------------

# Provider default used when UI sends `auto`.
# - local: Local S2-Pro engine (default, auto-started by the backend)
# - api: hosted Fish Audio API
S2_PRO_RUNTIME=local

# Local S2-Pro is started by the backend, like MMAudio/Applio/ACE-Step wrappers.
# Users normally do not run a separate server. On first S2-Pro generation or
# voice save, the backend starts `scripts/serve_s2_pro.sh` if the local endpoint
# is not already healthy.
S2_PRO_AUTO_START=1
S2_PRO_START_TIMEOUT_SEC=600

# Local Fish Speech compatible endpoint used by the backend-started process.
FISH_SPEECH_MODEL=s2-pro
FISH_SPEECH_SERVER_URL=http://127.0.0.1:8080
FISH_SPEECH_TIMEOUT_SEC=600

# Optional local compatible endpoint token. Usually empty for local use.
# FISH_SPEECH_API_KEY=

# Local S2-Pro model and process options. Leave paths unset to use:
# `data/models/fish-speech/s2-pro` and `.venv-fish-speech`.
# FISH_SPEECH_MODEL_DIR=
# FISH_SPEECH_VENV=
# FISH_SPEECH_PYTHON=python3.11
# FISH_SPEECH_HOST=127.0.0.1
# FISH_SPEECH_PORT=8080
FISH_SPEECH_HALF=1
FISH_SPEECH_COMPILE=0
FISH_SPEECH_WORKERS=1
FISH_SPEECH_DECODER_CONFIG=modded_dac_vq

# Fish Speech upstream can pin a different torch line. The local S2-Pro
# installer installs the selected torch family first, then installs Fish Speech
# without overriding the torch/torchaudio/torchvision line.
FISH_SPEECH_TORCH_VERSION=2.11.0
FISH_SPEECH_TORCH_PROFILE=cu130

# Hosted Fish Audio API. Required only when selecting the Fish Audio API
# provider in the UI, or when S2_PRO_RUNTIME=api.
# FISH_AUDIO_API_KEY=
FISH_AUDIO_API_URL=https://api.fish.audio
FISH_AUDIO_MODEL=s2-pro
FISH_AUDIO_TIMEOUT_SEC=600

# ---------------------------------------------------------------------------
# MMAudio sound effects
# ---------------------------------------------------------------------------

# Leave unset to use the vendored checkout and default Python.
# MMAUDIO_PYTHON_EXECUTABLE=
# MMAUDIO_INFER_SCRIPT=

# Use command templates when your MMAudio installation needs a custom launcher.
# Available placeholders are filled by the backend command wrapper.
# MMAUDIO_COMMAND_TEMPLATE=
# MMAUDIO_NSFW_COMMAND_TEMPLATE=

# Optional downloadable MMAudio assets.
# MMAUDIO_MODEL_URL=https://example.com/mmaudio-checkpoint.safetensors
# MMAUDIO_MODEL_FILENAME=
# MMAUDIO_CONFIG_URL=https://example.com/mmaudio-config.yaml
# MMAUDIO_CONFIG_FILENAME=
# MMAUDIO_NSFW_MODEL_URL=https://huggingface.co/phazei/NSFW_MMaudio/resolve/main/mmaudio_large_44k_nsfw_gold_8.5k_final_fp16.safetensors
# MMAUDIO_NSFW_MODEL_FILENAME=mmaudio_large_44k_nsfw_gold_8.5k_final_fp16.safetensors

# ---------------------------------------------------------------------------
# Applio / RVC voice conversion
# ---------------------------------------------------------------------------

# Leave unset to use the vendored checkout, default Python, and downloaded demo
# RVC model pair under `data/rvc-models`.
# APPLIO_PYTHON_EXECUTABLE=
# APPLIO_MODEL_DIR=
# APPLIO_MODEL_PATH=
# APPLIO_INDEX_PATH=
# APPLIO_BLEND_MODEL_A=
# APPLIO_BLEND_MODEL_B=

# Built-in demo RVC pair download controls.
APPLIO_SKIP_DEFAULT_RVC=0
# APPLIO_DEFAULT_RVC_MODEL_URL=https://huggingface.co/SmlCoke/rvc-yui/resolve/main/weights/yui-mix-pro-hq-40k.pth
# APPLIO_DEFAULT_RVC_INDEX_URL=https://huggingface.co/SmlCoke/rvc-yui/resolve/main/index/added_IVF1386_Flat_nprobe_1_yui-mix-pro-hq_v2.index
# APPLIO_DEFAULT_RVC_MODEL_FILENAME=yui-mix-pro-hq-40k.pth
# APPLIO_DEFAULT_RVC_INDEX_FILENAME=added_IVF1386_Flat_nprobe_1_yui-mix-pro-hq_v2.index

# Custom RVC pair download controls.
# APPLIO_RVC_MODEL_URL=https://example.com/my-rvc-model.pth
# APPLIO_RVC_MODEL_FILENAME=
# APPLIO_RVC_INDEX_URL=https://example.com/my-rvc-model.index
# APPLIO_RVC_INDEX_FILENAME=

# Applio runtime assets used during conversion/training. The download script
# fetches these so Applio does not try to download them mid-conversion.
# APPLIO_CONTENTVEC_MODEL_URL=https://huggingface.co/IAHispano/Applio/resolve/main/Resources/embedders/contentvec/pytorch_model.bin
# APPLIO_CONTENTVEC_CONFIG_URL=https://huggingface.co/IAHispano/Applio/resolve/main/Resources/embedders/contentvec/config.json
# APPLIO_RMVPE_URL=https://huggingface.co/IAHispano/Applio/resolve/main/Resources/predictors/rmvpe.pt

# ---------------------------------------------------------------------------
# Stem separator
# ---------------------------------------------------------------------------

# Used only by the Audio Separation tab. Qwen/S2-Pro TTS, voice saving, and
# Qwen3-ASR transcription do not need this model.
STEM_SEPARATOR_MODEL_FILENAME=vocals_mel_band_roformer.ckpt

# ---------------------------------------------------------------------------
# ACE-Step music
# ---------------------------------------------------------------------------

# ACE-Step runs in a separate subprocess/venv, matching the audio-tool wrapper
# pattern. Leave unset to use `.venv-ace-step` and `data/models/ace-step`.
# ACE_STEP_PYTHON=
# ACE_STEP_CHECKPOINT_PATH=
# ACE_STEP_LORA_DIR=
ACE_STEP_VENV=.venv-ace-step
ACE_STEP_DOWNLOAD_PROFILE=main

# ACE-Step adapter training stores LoRA/LoKr outputs here unless overridden.
# ACE_STEP_LORA_DIR=data/models/ace-step/loras

# ---------------------------------------------------------------------------
# Private Hugging Face asset mirror
# ---------------------------------------------------------------------------

# If set, download scripts look in this private repo before public fallbacks for
# Qwen, S2-Pro, Applio/RVC, MMAudio NSFW, and stem-separator assets.
# PRIVATE_ASSET_REPO_ID=your-hf-username/qwen3-tts-demo-assets
PRIVATE_ASSET_REVISION=main
QWEN_USE_PRIVATE_ASSET_REPO=0
HF_HUB_ENABLE_HF_TRANSFER=1
# HF_TOKEN=
