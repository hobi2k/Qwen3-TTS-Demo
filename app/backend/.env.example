# Copy this file to `app/backend/.env` and adjust if needed.

# Use real models by default after setup/download.
QWEN_DEMO_SIMULATION=0

# Leave unset for auto device detection. Recommended defaults on this repo:
# - Apple Silicon / CPU-only: cpu
# - NVIDIA CUDA: cuda:0
QWEN_DEMO_DEVICE=cpu

# Leave unset for auto attention selection. On Apple Silicon / CPU-only, use sdpa.
QWEN_DEMO_ATTN_IMPL=sdpa

# Local downloaded model directories created by scripts/download_models.sh
QWEN_DEMO_CUSTOM_MODEL=/Users/ahnhs2k/Desktop/personal/Qwen3-TTS-Demo/data/models/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_DEMO_DESIGN_MODEL=/Users/ahnhs2k/Desktop/personal/Qwen3-TTS-Demo/data/models/Qwen3-TTS-12Hz-1.7B-VoiceDesign
QWEN_DEMO_BASE_MODEL=/Users/ahnhs2k/Desktop/personal/Qwen3-TTS-Demo/data/models/Qwen3-TTS-12Hz-1.7B-Base
QWEN_DEMO_TOKENIZER_MODEL=/Users/ahnhs2k/Desktop/personal/Qwen3-TTS-Demo/data/models/Qwen3-TTS-Tokenizer-12Hz
