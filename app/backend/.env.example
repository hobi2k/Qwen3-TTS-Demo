# Copy this file to `app/backend/.env` and adjust if needed.

# Use real models by default after setup/download.
QWEN_DEMO_SIMULATION=0

# Leave unset for auto device detection.
# - Apple Silicon / CPU-only: auto-detects to mps or cpu
# - NVIDIA CUDA: auto-detects to cuda:0
# QWEN_DEMO_DEVICE=

# Leave unset for auto attention selection.
# - macOS / Apple Silicon: sdpa fallback
# - Windows or Ubuntu with CUDA + flash_attn installed: flash_attention_2
# - CPU-only: sdpa
# QWEN_DEMO_ATTN_IMPL=

# Local downloaded model directories created by scripts/download_models.sh
# Leave unset to auto-resolve from `data/models/*`.
# QWEN_DEMO_CUSTOM_MODEL=
# QWEN_DEMO_DESIGN_MODEL=
# QWEN_DEMO_BASE_MODEL=
# QWEN_DEMO_TOKENIZER_MODEL=

# Optional audio-tool repos cloned by scripts/setup_backend.*
MMAUDIO_REPO_URL=https://github.com/hkchengrex/MMAudio.git
APPLIO_REPO_URL=https://github.com/IAHispano/Applio.git
FISH_SPEECH_REPO_URL=https://github.com/fishaudio/fish-speech.git

# Optional local repo roots. If left unset, scripts/setup_backend.* use vendor/MMAudio and vendor/Applio.
# MMAUDIO_REPO_ROOT=
# APPLIO_REPO_ROOT=
# FISH_SPEECH_REPO_ROOT=

# Local Fish Speech S2-Pro runtime.
# Run `./scripts/download_models.sh s2pro`, then `./scripts/serve_s2_pro.sh`.
FISH_SPEECH_MODEL=s2-pro
FISH_SPEECH_SERVER_URL=http://127.0.0.1:8080
FISH_SPEECH_TIMEOUT_SEC=180
# Fish Speech upstream pins torch==2.8.0. The demo runtime overrides that pin
# so local S2-Pro can run on the same torch/CUDA line as Qwen.
FISH_SPEECH_TORCH_VERSION=2.11.0
FISH_SPEECH_TORCH_PROFILE=cu130
# FISH_SPEECH_MODEL_DIR=
# FISH_SPEECH_HOST=127.0.0.1
# FISH_SPEECH_PORT=8080
# FISH_SPEECH_HALF=1
# FISH_SPEECH_COMPILE=0

# Optional Python executables for external tool runtimes.
# MMAUDIO_PYTHON_EXECUTABLE=
# APPLIO_PYTHON_EXECUTABLE=

# Optional inference entrypoint override for MMAudio.
# MMAUDIO_INFER_SCRIPT=
# MMAUDIO_COMMAND_TEMPLATE=

# Optional downloadable assets for audio tools.
# If set, scripts/download_models.* will fetch these files.
# Private asset mirror. If this is set, download_models.* first looks here for
# RVC, MMAudio NSFW, and Stem Separator assets before falling back to public URLs.
# PRIVATE_ASSET_REPO_ID=your-hf-username/qwen3-tts-demo-assets
# PRIVATE_ASSET_REVISION=main
# QWEN_USE_PRIVATE_ASSET_REPO=0
# MMAUDIO_MODEL_URL=https://example.com/mmaudio-checkpoint.safetensors
# MMAUDIO_MODEL_FILENAME=
# MMAUDIO_CONFIG_URL=https://example.com/mmaudio-config.yaml
# MMAUDIO_CONFIG_FILENAME=
# APPLIO_RVC_MODEL_URL=https://example.com/my-rvc-model.pth
# APPLIO_RVC_MODEL_FILENAME=
# APPLIO_RVC_INDEX_URL=https://example.com/my-rvc-model.index
# APPLIO_RVC_INDEX_FILENAME=
# STEM_SEPARATOR_MODEL_FILENAME=vocals_mel_band_roformer.ckpt
